{
  "info": {
    "name": "FixItNow API Collection",
    "description": "Postman Collection covering all endpoints of the FixItNow Backend API (Customer, Technician, and Admin roles).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"CUSTOMER\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"customer@fixitnow.com\",\n  \"password\": \"customer123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Authenticated User",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/auth/me",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
    {
      "name": "Services & Technicians (Public)",
      "item": [
        {
          "name": "Get All Services (with Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/services?location=New York&minRating=4.0&minPrice=10&maxPrice=150",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "services"],
              "query": [
                { "key": "location", "value": "New York" },
                { "key": "minRating", "value": "4.0" },
                { "key": "minPrice", "value": "10" },
                { "key": "maxPrice", "value": "150" }
              ]
            }
          }
        },
        {
          "name": "Get All Technicians (with Filters)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/technicians?location=New York&minRating=4.0",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "technicians"],
              "query": [
                { "key": "location", "value": "New York" },
                { "key": "minRating", "value": "4.0" }
              ]
            }
          }
        },
        {
          "name": "Get Technician Profile & Reviews",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/technicians/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "technicians", ":id"],
              "variable": [{ "key": "id", "value": "technician-profile-uuid" }]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking Request (Customer)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceId\": \"service-uuid-here\",\n  \"scheduledTime\": \"2026-07-20T10:00:00.000Z\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/bookings",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "bookings"]
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/bookings",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "bookings"]
            }
          }
        },
        {
          "name": "Get Booking Details",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/bookings/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "bookings", ":id"],
              "variable": [{ "key": "id", "value": "booking-uuid" }]
            }
          }
        }
      ]
    },
    {
      "name": "Payments (Stripe)",
      "item": [
        {
          "name": "Create Stripe Checkout Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bookingId\": \"booking-uuid-here\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/payments/create-checkout-session",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "payments", "create-checkout-session"]
            }
          }
        },
        {
          "name": "Verify & Confirm Stripe Payment",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/payments/confirm?session_id=cs_test_session_id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "payments", "confirm"],
              "query": [{ "key": "session_id", "value": "cs_test_session_id" }]
            }
          }
        },
        {
          "name": "Get Payment History",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/payments/history",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "payments", "history"]
            }
          }
        }
      ]
    },
    {
      "name": "Technician Management",
      "item": [
        {
          "name": "Update Profile Details",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"skills\": [\"Plumbing\", \"Pipe Leak Fixes\"],\n  \"experience\": \"6 years\",\n  \"pricing\": 55.0,\n  \"location\": \"San Francisco\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/technician/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "technician", "profile"]
            }
          }
        },
        {
          "name": "Update Weekly Availability Slots",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"availability\": [\"Mon 10:00-18:00\", \"Wed 10:00-18:00\"]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/technician/availability",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "technician", "availability"]
            }
          }
        },
        {
          "name": "Get Technician Bookings",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "url": {
              "raw": "http://localhost:5000/api/technician/bookings",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "technician", "bookings"]
            }
          }
        },
        {
          "name": "Update Booking Status (Accept/Decline/Complete)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"ACCEPTED\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/technician/bookings/:id",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "technician", "bookings", ":id"],
              "variable": [{ "key": "id", "value": "booking-uuid" }]
            }
          }
        }
      ]
    },
    {
